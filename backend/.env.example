# Backend environment variables example
# Copy this file to .env and replace the placeholder values.

MONGO_URI=mongodb://localhost:
MONGO_DB=grocery_intelligence
REDIS_URL=redis://localhost:
SECRET_KEY=replace-with-a-secure-random-secret
CREDENTIAL_ENCRYPTION_KEY=replace-with-fernet-key
OCR_CONFIDENCE_THRESHOLD_REVIEW=0.70
OCR_CONFIDENCE_THRESHOLD_ACCEPT=0.85
FETCH_POINTS_PER_DOLLAR=1000
